# RFID Gate System - Environment Variables

# Database Configuration
DATABASE_URL=postgresql://rfid_user:rfid_password@localhost:5432/rfid_gate

# FastAPI Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ESP32 Configuration (these go in ESP32 code as well)
ESP32_WIFI_SSID=YOUR_WIFI_SSID
ESP32_WIFI_PASSWORD=YOUR_WIFI_PASSWORD
ESP32_BACKEND_URL=http://YOUR_SERVER_IP:8000

# Logging
LOG_LEVEL=INFO
